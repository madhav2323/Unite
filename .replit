modules = ["nodejs-24", "python-3.11", "java-graalvm22.3"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "vm"
build = ["bash", "-c", "BASE_PATH=/ pnpm --filter @workspace/code-editor run build && pnpm --filter @workspace/api-server run build"]
run = ["bash", "-c", "NODE_ENV=production node artifacts/api-server/dist/index.cjs"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
